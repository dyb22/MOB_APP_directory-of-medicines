# Скопируйте в .env: cp .env.example .env и заполните.
# IP или DNS, с которого вы заходите к ВМ в браузере (без порта).
HOST_IP=192.168.91.222

# --- Gitea (уже используется) ---
GITEA_ROOT_URL=http://192.168.91.222:3000/

# --- Wiki.js (отдельная wiki) ---
# Пароль БД Postgres для Wiki.js (придумайте свой).
WIKIJS_DB_PASSWORD=change_me_wiki_db

# --- Drone ---
# Один и тот же секрет на сервере и runner; сгенерируйте: openssl rand -hex 16
DRONE_RPC_SECRET=
# В Gitea: Настройки → Приложения → Создать OAuth2 — Redirect URI: http://HOST_IP:9000/login
DRONE_GITEA_CLIENT_ID=
DRONE_GITEA_CLIENT_SECRET=

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=change_me_grafana
