<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/profile_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/profile_app_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/profile_login_instruction"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/input_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_rounded"
            android:gravity="center_vertical"
            android:hint="@string/profile_email_hint"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp" />

        <EditText
            android:id="@+id/input_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_rounded"
            android:gravity="center_vertical"
            android:hint="@string/profile_password_hint"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp" />

        <TextView
            android:id="@+id/text_auth_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:text="@string/profile_auth_error_invalid_credentials"
            android:textColor="@color/error_red"
            android:textSize="12sp"
            android:textStyle="normal"
            android:textAlignment="center"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_login"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_black"
            app:backgroundTint="@null"
            android:text="@string/profile_login_button"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/button_register"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_black"
            app:backgroundTint="@null"
            android:text="@string/profile_register_button"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>
