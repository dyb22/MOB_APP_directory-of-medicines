<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="18dp"
        android:paddingTop="40dp"
        android:background="@color/white">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:text="@string/search_title"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_field"
            android:hint="@string/search_hint"
            android:inputType="text"
            android:paddingHorizontal="16dp" />

        <ImageButton
            android:id="@+id/button_camera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_search_field"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_camera" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_results_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_gravity="center_horizontal"
        android:text="@string/search_results_title"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="@color/black"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_nothing_found"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:gravity="center"
        android:paddingBottom="280dp"
        android:text="@string/search_nothing_found"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:visibility="gone" />

        <ListView
        android:id="@+id/search_results_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

    </LinearLayout>

    <include
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        layout="@layout/view_loading_overlay" />

    <LinearLayout
        android:id="@+id/no_network_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/no_network_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/search_no_network"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/no_network_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_wifi_off_crossed"
            android:contentDescription="@null" />
    </LinearLayout>

</FrameLayout>
